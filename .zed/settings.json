{
  "file_scan_exclusions": [
    "**/.svn",
    "**/.hg",
    "**/.jj",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.classpath",
    "**/.settings"
  ],
  "format_on_save": "on",
  "languages": {
    "OCaml": {
      "language_servers": ["ocamllsp"],
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "make",
          "arguments": ["--silent", "fmt", "ZED_FORMAT_FILE={buffer_path}"]
        }
      }
    }
  }
}
